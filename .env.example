# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables.

# Spotify Web API (https://developer.spotify.com/dashboard)
# Create an app while logged into Spotify (e.g. josephmeyer2016@gmail.com). S4A "admin" does not replace these.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Stripe (Dashboard → Developers → API keys). Use test keys for checkout testing.
STRIPE_SECRET_KEY=
# Optional: canonical site URL for Stripe redirect URLs if Origin header is missing (e.g. server-side calls)
NEXT_PUBLIC_APP_URL=
