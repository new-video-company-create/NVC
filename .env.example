# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables.

# Spotify Web API (https://developer.spotify.com/dashboard)
# Create an app while logged into Spotify (e.g. josephmeyer2016@gmail.com). S4A "admin" does not replace these.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Stripe (one place per environment) ---
# 1) https://dashboard.stripe.com/register — create or sign in to Stripe.
# 2) Developers → API keys — reveal "Secret key" (test: sk_test_…, live: sk_live_…).
# 3) Paste only the Secret key here — never commit real keys; use Vercel env in production.
# 4) Redeploy after changing env on Vercel. Health check: GET /api/stripe/health
STRIPE_SECRET_KEY=
# 5) Optional: your public site URL so Checkout success/cancel URLs are correct if Origin is missing.
NEXT_PUBLIC_APP_URL=
